{% extends 'layouts/app.twig' %}

{% block content %}
    <section class="-mx-8 -mt-8 border-b border-[var(--yellow)] bg-[var(--light)] px-8 pb-5 pt-8">
        <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-primary text-3xl font-bold">
                        Oi, {{ user.name }}!
                    </p>
                    <p class="mt-2 max-w-2xl text-sm opacity-75">
                        confira seu fluxo até o próximo respiro:
                    </p>
                </div>
                <button type="button" class="flex h-10 w-10 flex-none items-center justify-center rounded text-primary transition hover:bg-[var(--yellow)]" title="Atualizar dados" aria-label="Atualizar dados" data-refresh-home>
                    <i class="fa-solid fa-rotate-right"></i>
                </button>
            </div>

            <div class="grid grid-cols-2 gap-3 xl:min-w-[680px]">
                <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-3">
                    <p class="text-xs text-secondary">saldo do ciclo</p>
                    <strong class="mt-1 block text-xl font-semibold text-primary" data-viewed-cycle-balance>{{ dashboard.currentCycle.balanceLabel }}</strong>
                </div>
                <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-3">
                    <p class="text-xs text-secondary">comprometido</p>
                    <strong class="mt-1 block text-xl font-semibold">{{ dashboard.balance.commitedLabel }}</strong>
                </div>
            </div>
        </div>

        <div class="mt-5 grid gap-3 md:grid-cols-[1fr_auto] md:items-center">
            <div>
                <div class="flex items-center justify-between text-xs">
                    <span class="text-secondary">progresso do ciclo <span data-viewed-cycle-progress-label>{{ dashboard.currentCycle.label }}</span></span>
                    <span class="text-purple" data-viewed-cycle-progress-value>{{ dashboard.currentCycle.progress }}%</span>
                </div>
                <div class="mt-2 h-2 overflow-hidden rounded-full bg-[var(--yellow)]">
                    <div class="h-full rounded-full bg-[var(--lilac)] transition-all duration-300" style="width: {{ dashboard.currentCycle.progress }}%" data-viewed-cycle-progress-bar></div>
                </div>
            </div>

            <div class="flex rounded bg-[var(--yellow)] p-1 text-xs text-primary">
                <button class="rounded bg-[var(--lilac)] px-3 py-1 font-semibold text-light">ciclo</button>
                <button class="rounded px-3 py-1">data</button>
                <button class="rounded px-3 py-1">categoria</button>
                <button class="rounded px-3 py-1">wallet</button>
            </div>
        </div>
    </section>

    <section class="mt-8 grid grid-cols-1 gap-8 2xl:grid-cols-[minmax(0,1fr)_320px]">
        <div class="space-y-6">
            <nav class="flex items-center justify-between gap-3" aria-label="Navegar entre ciclos">
                <button type="button" class="flex items-center gap-2 rounded px-3 py-2 text-sm text-primary transition hover:bg-[var(--yellow)] disabled:cursor-wait disabled:opacity-50" data-cycle-previous>
                    <i class="fa-solid fa-chevron-left"></i>
                    <span>ciclo anterior</span>
                </button>
                {# Abre a versão do ciclo preparada para impressão #}
                <button type="button" class="flex items-center gap-2 rounded px-3 py-2 text-sm text-primary transition hover:bg-[var(--yellow)] disabled:cursor-wait disabled:opacity-50" data-print-cycle data-print-url="{{ base_url }}/dashboard/cycle/print/">
                    <i class="fa-solid fa-download"></i>
                    <span class="hidden sm:inline">exportar</span>
                </button>
                <button type="button" class="flex items-center gap-2 rounded px-3 py-2 text-sm text-primary transition hover:bg-[var(--yellow)] disabled:cursor-wait disabled:opacity-50" data-cycle-next>
                    <span>pr&oacute;ximo ciclo</span>
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </nav>

            <article class="relative rounded border border-[var(--yellow)] bg-[#fffff5] p-5" data-cycle-card data-cycle-url="{{ base_url }}/dashboard/cycle/" data-cycle-start="{{ dashboard.currentCycle.start|e('html_attr') }}" data-cycle-end="{{ dashboard.currentCycle.end|e('html_attr') }}">
                <header>
                    <button type="button" class="grid w-full gap-4 text-left md:grid-cols-[auto_1fr_auto_auto] md:items-center" data-cycle-toggle aria-expanded="true">
                        <div class="flex h-14 w-14 items-center justify-center rounded-full bg-[var(--yellow)] text-primary">
                            <span class="text-lg font-semibold" data-cycle-start-day>{{ dashboard.currentCycle.startDayLabel }}</span>
                        </div>
                        <div>
                            <h2 class="text-xl font-semibold text-primary" data-cycle-label>{{ dashboard.currentCycle.label }}</h2>
                            <p class="mt-1 text-sm opacity-70" data-cycle-description>ciclo atual at&eacute; o pr&oacute;ximo recebimento</p>
                        </div>
                        <div class="grid grid-cols-3 gap-3 text-right text-xs md:min-w-[360px]">
                            <div>
                                <p class="text-secondary">recebe</p>
                                <strong class="block text-sm text-primary" data-cycle-income>{{ dashboard.currentCycle.incomeLabel }}</strong>
                            </div>
                            <div>
                                <p class="text-secondary">gastos</p>
                                <strong class="block text-sm text-purple" data-cycle-expenses>{{ dashboard.currentCycle.expensesLabel }}</strong>
                            </div>
                            <div>
                                <p class="text-secondary">sobra</p>
                                <strong class="block text-sm text-[var(--dark)]" data-cycle-balance>{{ dashboard.currentCycle.balanceLabel }}</strong>
                            </div>
                        </div>
                        <span class="flex h-9 w-9 items-center justify-center rounded text-primary transition hover:bg-[var(--yellow)]" aria-hidden="true">
                            <i class="fa-solid fa-chevron-up transition-transform duration-200" data-cycle-icon></i>
                        </span>
                    </button>
                </header>

                <div class="mt-5 space-y-3 pl-0 transition-[max-height,margin-top] duration-300 ease-in-out md:pl-20" data-cycle-content>
                    {% for transaction in dashboard.currentCycle.transactions %}
                        <button type="button" class="grid w-full gap-3 rounded border border-[var(--yellow)] bg-[var(--light)] p-3 text-left transition hover:-translate-y-0.5 hover:shadow-md {% if transaction.paid %}opacity-80{% endif %} sm:grid-cols-[1fr_auto] sm:items-center" data-edit-transaction data-transaction-id="{{ transaction.id|e('html_attr') }}" data-transaction-title="{{ transaction.title|e('html_attr') }}" data-transaction-amount="{{ transaction.form_amount_label|e('html_attr') }}" data-transaction-occurrence-date="{{ transaction.occurrence_date|e('html_attr') }}" data-transaction-due-date="{{ transaction.due_date|e('html_attr') }}" data-transaction-paid-at="{{ transaction.paid_at|e('html_attr') }}" data-transaction-paid="{{ transaction.paid|e('html_attr') }}" data-transaction-wallet-id="{{ transaction.wallet.id|e('html_attr') }}" data-transaction-wallet-name="{{ transaction.wallet.name|e('html_attr') }}" data-transaction-category-id="{{ transaction.category.id|e('html_attr') }}" data-transaction-category-name="{{ transaction.category.name|e('html_attr') }}" data-transaction-entity-id="{{ transaction.entity.id|e('html_attr') }}" data-transaction-entity-name="{{ transaction.entity.name|e('html_attr') }}" data-transaction-template-id="{{ transaction.template.id|e('html_attr') }}" data-transaction-template-name="{{ transaction.template.title|e('html_attr') }}" data-transaction-payment-method-id="{{ transaction.payment_method.id|e('html_attr') }}" data-transaction-payment-method-name="{{ transaction.payment_method.name|e('html_attr') }}">
                            <div class="flex items-center gap-3">
                                <div class="flex h-10 w-10 items-center justify-center rounded-full text-light" style="background-color: {{ transaction.category.color|e('html_attr') }}">
                                    <i class="{{ transaction.category.icon|e('html_attr') }}"></i>
                                </div>
                                <div>
                                    <h3 class="font-medium">{{ transaction.title }}</h3>
                                    <p class="text-xs text-secondary">{{ transaction.meta_label }}</p>
                                </div>
                            </div>
                            <div class="flex items-center justify-between gap-4 sm:block sm:text-right">
                                <span class="text-xs text-secondary">{{ transaction.date_label }}</span>
                                <strong class="block text-sm {% if transaction.amount > 0 %}text-primary{% else %}text-[var(--dark)]{% endif %}">{{ transaction.amount_label }}</strong>
                                <span class="badge">{{ transaction.status_label }}</span>
                            </div>
                        </button>
                    {% else %}
                        <div class="rounded border border-[var(--yellow)] bg-[var(--light)] p-4 text-sm text-secondary">
                            nenhum lançamento neste ciclo.
                        </div>
                    {% endfor %}
                </div>
            </article>

            {# Exibe os resumos de despesas do ciclo selecionado #}
            <article class="rounded border border-[var(--yellow)] bg-[#fffff5] p-5">
                <div class="grid gap-8 md:grid-cols-2">
                    {# Agrupa as despesas por entidade #}
                    <section>
                        <h2 class="font-semibold text-primary">gastos por entidade</h2>
                        <div class="mt-4 space-y-4" data-entity-summary>
                            {# Percorre os totais calculados para cada entidade #}
                            {% for item in dashboard.currentCycle.entitySummary %}
                                <div>
                                    <div class="flex items-center justify-between gap-4 text-sm">
                                        <span class="truncate">{{ item.label }}</span>
                                        <strong>{{ item.amountLabel }}</strong>
                                    </div>
                                    <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-[var(--yellow)]">
                                        <div class="h-full rounded-full bg-[var(--lilac)] transition-all duration-300" style="width: {{ item.percentage }}%"></div>
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-sm text-secondary">nenhuma sa&iacute;da neste ciclo.</p>
                            {% endfor %}
                        </div>
                    </section>

                    {# Agrupa as despesas por categoria #}
                    <section>
                        <h2 class="font-semibold text-primary">gastos por categoria</h2>
                        <div class="mt-4 space-y-4" data-category-summary>
                            {# Percorre os totais calculados para cada categoria #}
                            {% for item in dashboard.currentCycle.categorySummary %}
                                <div>
                                    <div class="flex items-center justify-between gap-4 text-sm">
                                        <span class="truncate">{{ item.label }}</span>
                                        <strong>{{ item.amountLabel }}</strong>
                                    </div>
                                    <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-[var(--yellow)]">
                                        <div class="h-full rounded-full bg-[var(--lilac)] transition-all duration-300" style="width: {{ item.percentage }}%"></div>
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-sm text-secondary">nenhuma sa&iacute;da neste ciclo.</p>
                            {% endfor %}
                        </div>
                    </section>
                </div>
            </article>
        </div>

        <aside class="space-y-4 2xl:min-w-[320px]">
            <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-4">
                <h2 class="font-semibold text-primary">próximos marcos</h2>
                <div class="mt-4 space-y-3">
                    {% for milestone in dashboard.milestones %}
                        <div class="flex items-center justify-between gap-3">
                            <div>
                                <p class="text-sm font-medium">{{ milestone.title }}</p>
                                <p class="text-xs text-secondary">{{ milestone.dateLabel }}</p>
                            </div>
                            <strong class="text-sm {% if milestone.amount > 0 %}text-primary{% endif %}">{{ milestone.amountLabel }}</strong>
                        </div>
                    {% else %}
                        <p class="text-sm text-secondary">nenhum marco previsto.</p>
                    {% endfor %}
                </div>
            </div>

            <button type="button" class="modal-toggle btn-primary fixed bottom-20 right-6 flex h-12 w-12 items-center justify-center rounded-full text-xl shadow-lg md:hidden" data-modal-target="#transaction-modal" aria-label="Novo registro">
                <i class="fa-solid fa-plus"></i>
            </button>
        </aside>
    </section>
{% endblock %}

{% block scripts %}
    <script src="{{ base_url }}/assets/js/home.js"></script>
{% endblock %}
