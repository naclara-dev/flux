{% extends 'layouts/app.twig' %}

{% block content %}
    <section class="-mx-8 -mt-8 border-b border-[var(--yellow)] bg-[var(--light)] px-8 pb-5 pt-8">
        <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
            <div class="flex items-start justify-between gap-4">
                <div>
                    <p class="text-primary text-3xl font-bold">
                        Oi, {{ user.name }}!
                    </p>
                    <p class="mt-2 max-w-2xl text-sm opacity-75">
                        confira seu fluxo até o próximo respiro:
                    </p>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3 xl:min-w-[680px]">
                <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-3">
                    <p class="text-xs text-secondary">saldo do ciclo</p>
                    <strong class="mt-1 block text-xl font-semibold text-primary" data-viewed-cycle-balance>{{ dashboard.currentCycle.balanceLabel }}</strong>
                </div>
                <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-3">
                    <p class="text-xs text-secondary">comprometido</p>
                    <strong class="mt-1 block text-xl font-semibold">{{ dashboard.balance.commitedLabel }}</strong>
                </div>
            </div>
        </div>

        <div class="mt-5">
            {# Exibe o feedback temporario das acoes da dashboard #}
            {% if dashboard_feedback|default(null) %}
                <div class="mb-4 flex items-start gap-3 rounded border border-[var(--lilac)] bg-[rgba(193,127,215,0.08)] px-3 py-3 text-sm text-primary" role="alert">
                    <i class="fa-solid fa-circle-check mt-0.5"></i>
                    <span>{{ dashboard_feedback.message }}</span>
                </div>
            {% endif %}

            <div>
                <div class="flex items-center justify-between text-xs">
                    <span class="text-secondary">progresso do ciclo <span data-viewed-cycle-progress-label>{{ dashboard.currentCycle.label }}</span></span>
                    <span class="text-purple" data-viewed-cycle-progress-value>{{ dashboard.currentCycle.progress }}%</span>
                </div>
                <div class="mt-2 h-2 overflow-hidden rounded-full bg-[var(--yellow)]">
                    <div class="h-full rounded-full bg-[var(--lilac)] transition-all duration-300" style="width: {{ dashboard.currentCycle.progress }}%" data-viewed-cycle-progress-bar></div>
                </div>
            </div>

            {# Agrupa as acoes principais da dashboard em uma toolbar expansivel #}
            <div class="mt-4 flex flex-wrap items-center gap-1" aria-label="Acoes da dashboard">
                {# Recarrega os dados exibidos na dashboard #}
                <button type="button" class="group flex h-9 items-center gap-1.5 overflow-hidden rounded px-2 text-sm text-primary transition hover:bg-[var(--yellow)] focus-visible:bg-[var(--yellow)] focus-visible:outline-none disabled:cursor-wait disabled:opacity-50" title="Atualizar dados" aria-label="Atualizar dados" data-refresh-home>
                    <i class="fa-solid fa-rotate-right flex w-5 justify-center"></i>
                    <span class="max-w-0 -translate-x-1 overflow-hidden whitespace-nowrap opacity-0 transition-all duration-200 ease-out group-hover:max-w-28 group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:max-w-28 group-focus-visible:translate-x-0 group-focus-visible:opacity-100">recarregar</span>
                </button>

                {# Abre a versao do ciclo preparada para impressao #}
                <button type="button" class="group flex h-9 items-center gap-1.5 overflow-hidden rounded px-2 text-sm text-primary transition hover:bg-[var(--yellow)] focus-visible:bg-[var(--yellow)] focus-visible:outline-none disabled:cursor-wait disabled:opacity-50" title="Exportar ciclo" aria-label="Exportar ciclo" data-print-cycle data-print-url="{{ base_url }}/dashboard/cycle/print/">
                    <i class="fa-solid fa-download flex w-5 justify-center"></i>
                    <span class="max-w-0 -translate-x-1 overflow-hidden whitespace-nowrap opacity-0 transition-all duration-200 ease-out group-hover:max-w-24 group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:max-w-24 group-focus-visible:translate-x-0 group-focus-visible:opacity-100">exportar</span>
                </button>

                {# Envia a solicitacao de geracao de registros periodicos #}
                <form method="post" action="{{ base_url }}/dashboard/periodic/generate/" data-confirm-form data-confirm-preset="periodic">
                    <button type="submit" class="group flex h-9 items-center gap-1.5 overflow-hidden rounded px-2 text-sm text-primary transition hover:bg-[var(--yellow)] focus-visible:bg-[var(--yellow)] focus-visible:outline-none disabled:cursor-wait disabled:opacity-60" title="Inserir previsoes" aria-label="Inserir previsoes">
                        <i class="fa-solid fa-calendar-plus flex w-5 justify-center"></i>
                        <span class="max-w-0 -translate-x-1 overflow-hidden whitespace-nowrap opacity-0 transition-all duration-200 ease-out group-hover:max-w-40 group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:max-w-40 group-focus-visible:translate-x-0 group-focus-visible:opacity-100">inserir previs&otilde;es</span>
                    </button>
                </form>

                {# Envia a solicitacao de encerramento do ciclo atual #}
                <form method="post" action="{{ base_url }}/dashboard/cycle/close/" data-confirm-form data-confirm-preset="close-cycle">
                    <button type="submit" class="group flex h-9 items-center gap-1.5 overflow-hidden rounded px-2 text-sm text-primary transition hover:bg-[var(--yellow)] focus-visible:bg-[var(--yellow)] focus-visible:outline-none disabled:cursor-wait disabled:opacity-60" title="Encerrar ciclo" aria-label="Encerrar ciclo">
                        <i class="fa-solid fa-circle-check flex w-5 justify-center"></i>
                        <span class="max-w-0 -translate-x-1 overflow-hidden whitespace-nowrap opacity-0 transition-all duration-200 ease-out group-hover:max-w-32 group-hover:translate-x-0 group-hover:opacity-100 group-focus-visible:max-w-32 group-focus-visible:translate-x-0 group-focus-visible:opacity-100">encerrar ciclo</span>
                    </button>
                </form>
            </div>
        </div>
    </section>

    <section class="mt-8 grid grid-cols-1 gap-8 2xl:grid-cols-[minmax(0,1fr)_320px]">
        <div class="space-y-6">
            <nav class="flex items-center justify-between gap-3" aria-label="Navegar entre ciclos">
                <button type="button" class="flex items-center gap-2 rounded px-3 py-2 text-sm text-primary transition hover:bg-[var(--yellow)] disabled:cursor-wait disabled:opacity-50" data-cycle-previous>
                    <i class="fa-solid fa-chevron-left"></i>
                    <span>ciclo anterior</span>
                </button>
                <button type="button" class="flex items-center gap-2 rounded px-3 py-2 text-sm text-primary transition hover:bg-[var(--yellow)] disabled:cursor-wait disabled:opacity-50" data-cycle-next>
                    <span>pr&oacute;ximo ciclo</span>
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </nav>

            <article class="relative rounded border border-[var(--yellow)] bg-[#fffff5] p-5" data-cycle-card data-cycle-url="{{ base_url }}/dashboard/cycle/" data-transaction-delete-url="{{ base_url }}/transactions/delete/" data-cycle-start="{{ dashboard.currentCycle.start|e('html_attr') }}" data-cycle-end="{{ dashboard.currentCycle.end|e('html_attr') }}">
                <header>
                    <button type="button" class="grid w-full gap-4 text-left md:grid-cols-[auto_1fr_auto_auto] md:items-center" data-cycle-toggle aria-expanded="true">
                        <div class="flex h-14 w-14 items-center justify-center rounded-full bg-[var(--yellow)] text-primary">
                            <span class="text-lg font-semibold" data-cycle-start-day>{{ dashboard.currentCycle.startDayLabel }}</span>
                        </div>
                        <div>
                            <h2 class="text-xl font-semibold text-primary" data-cycle-label>{{ dashboard.currentCycle.label }}</h2>
                            <p class="mt-1 text-sm opacity-70" data-cycle-description>ciclo atual at&eacute; o pr&oacute;ximo recebimento</p>
                        </div>
                        <div class="grid grid-cols-3 gap-3 text-right text-xs md:min-w-[360px]">
                            <div>
                                <p class="text-secondary">recebe</p>
                                <strong class="block text-sm text-primary" data-cycle-income>{{ dashboard.currentCycle.incomeLabel }}</strong>
                            </div>
                            <div>
                                <p class="text-secondary">gastos</p>
                                <strong class="block text-sm text-purple" data-cycle-expenses>{{ dashboard.currentCycle.expensesLabel }}</strong>
                            </div>
                            <div>
                                <p class="text-secondary">sobra</p>
                                <strong class="block text-sm text-[var(--dark)]" data-cycle-balance>{{ dashboard.currentCycle.balanceLabel }}</strong>
                            </div>
                        </div>
                        <span class="flex h-9 w-9 items-center justify-center rounded text-primary transition hover:bg-[var(--yellow)]" aria-hidden="true">
                            <i class="fa-solid fa-chevron-up transition-transform duration-200" data-cycle-icon></i>
                        </span>
                    </button>
                </header>

                <div class="mt-5 space-y-3 pl-0 transition-[max-height,margin-top] duration-300 ease-in-out md:pl-20" data-cycle-content>
                    {# Percorre as transações e separa a exclusão da ação de edição #}
                    {% for transaction in dashboard.currentCycle.transactions %}
                        <div class="group relative flex items-center gap-2 md:block">
                            {# Envia a exclusão pelo modal de confirmação compartilhado #}
                            <form method="post" action="{{ base_url }}/transactions/delete/" class="shrink-0 md:absolute md:-left-12 md:top-1/2 md:-translate-y-1/2">
                                <input type="hidden" name="id" value="{{ transaction.id|e('html_attr') }}">
                                <button type="submit" class="flex h-9 w-9 cursor-pointer items-center justify-center text-secondary" aria-label="Excluir transação" title="Excluir transação" data-delete-button>
                                    <i class="fa-regular fa-trash-can"></i>
                                </button>
                            </form>

                            <button type="button" class="grid min-w-0 flex-1 gap-3 rounded border border-[var(--yellow)] bg-[var(--light)] p-3 text-left md:w-full {% if transaction.paid %}opacity-80{% endif %} sm:grid-cols-[1fr_auto] sm:items-center" data-edit-transaction data-transaction-id="{{ transaction.id|e('html_attr') }}">
                                <div class="flex items-center gap-3">
                                    <div class="flex h-10 w-10 items-center justify-center rounded-full text-light" style="background-color: {{ transaction.category.color|e('html_attr') }}">
                                        <i class="{{ transaction.category.icon|e('html_attr') }}"></i>
                                    </div>
                                    <div>
                                        <h3 class="font-medium">{{ transaction.title }}</h3>
                                        <p class="text-xs text-secondary">{{ transaction.meta_label }}</p>
                                    </div>
                                </div>
                                <div class="flex items-center justify-between gap-4 sm:block sm:text-right">
                                    <span class="text-xs text-secondary">{{ transaction.date_label }}</span>
                                    <strong class="block text-sm {% if transaction.type == 'I' %}text-primary{% else %}text-[var(--dark)]{% endif %}">{{ transaction.amount_label }}</strong>
                                    <span class="badge">{{ transaction.status_label }}</span>
                                </div>
                            </button>
                        </div>
                    {% else %}
                        <div class="rounded border border-[var(--yellow)] bg-[var(--light)] p-4 text-sm text-secondary">
                            nenhum lançamento neste ciclo.
                        </div>
                    {% endfor %}
                </div>
            </article>

            {# Exibe os resumos de despesas do ciclo selecionado #}
            <article class="rounded border border-[var(--yellow)] bg-[#fffff5] p-5">
                <div class="grid gap-8 md:grid-cols-2">
                    {# Agrupa as despesas por entidade #}
                    <section>
                        <h2 class="font-semibold text-primary">gastos por entidade</h2>
                        <div class="mt-4 space-y-4" data-entity-summary>
                            {# Percorre os totais calculados para cada entidade #}
                            {% for item in dashboard.currentCycle.entitySummary %}
                                <div>
                                    <div class="flex items-center justify-between gap-4 text-sm">
                                        <span class="truncate">{{ item.label }}</span>
                                        <strong>{{ item.amountLabel }}</strong>
                                    </div>
                                    <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-[var(--yellow)]">
                                        <div class="h-full rounded-full bg-[var(--lilac)] transition-all duration-300" style="width: {{ item.percentage }}%"></div>
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-sm text-secondary">nenhuma sa&iacute;da neste ciclo.</p>
                            {% endfor %}
                        </div>
                    </section>

                    {# Agrupa as despesas por categoria #}
                    <section>
                        <h2 class="font-semibold text-primary">gastos por categoria</h2>
                        <div class="mt-4 space-y-4" data-category-summary>
                            {# Percorre os totais calculados para cada categoria #}
                            {% for item in dashboard.currentCycle.categorySummary %}
                                <div>
                                    <div class="flex items-center justify-between gap-4 text-sm">
                                        <span class="truncate">{{ item.label }}</span>
                                        <strong>{{ item.amountLabel }}</strong>
                                    </div>
                                    <div class="mt-1.5 h-1.5 overflow-hidden rounded-full bg-[var(--yellow)]">
                                        <div class="h-full rounded-full bg-[var(--lilac)] transition-all duration-300" style="width: {{ item.percentage }}%"></div>
                                    </div>
                                </div>
                            {% else %}
                                <p class="text-sm text-secondary">nenhuma sa&iacute;da neste ciclo.</p>
                            {% endfor %}
                        </div>
                    </section>
                </div>
            </article>
        </div>

        <aside class="space-y-4 2xl:min-w-[320px]">
            <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-4">
                <h2 class="font-semibold text-primary">próximos marcos</h2>
                <div class="mt-4 space-y-3">
                    {% for milestone in dashboard.milestones %}
                        <div class="flex items-center justify-between gap-3">
                            <div>
                                <p class="text-sm font-medium">{{ milestone.title }}</p>
                                <p class="text-xs text-secondary">{{ milestone.dateLabel }}</p>
                            </div>
                            <strong class="text-sm {% if milestone.type == 'I' %}text-primary{% endif %}">{{ milestone.amountLabel }}</strong>
                        </div>
                    {% else %}
                        <p class="text-sm text-secondary">nenhum marco previsto.</p>
                    {% endfor %}
                </div>
            </div>

            <button type="button" class="modal-toggle fixed bottom-24 right-5 flex h-14 w-14 cursor-pointer items-center justify-center rounded-full bg-[var(--yellow)] text-2xl text-[var(--lilac)] shadow-lg md:hidden" data-modal-target="#transaction-modal" aria-label="Novo registro">
                <i class="fa-solid fa-plus"></i>
            </button>
        </aside>
    </section>
{% endblock %}

{% block scripts %}
    <script src="{{ base_url }}/assets/js/home.js"></script>
{% endblock %}
