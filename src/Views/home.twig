{% extends 'layouts/app.twig' %}

{% block content %}
    <section class="sticky top-0 z-20 -mx-8 -mt-8 border-b border-[var(--yellow)] bg-[var(--light)] px-8 pb-5 pt-8">
        <div class="flex flex-col gap-5 xl:flex-row xl:items-end xl:justify-between">
            <div>
                <p class="text-primary text-3xl font-bold">
                    Oi, {{ user.name }}!
                </p>
                <p class="mt-2 max-w-2xl text-sm opacity-75">
                    Confira seu fluxo até o próximo respiro.
                </p>
            </div>

            <div class="grid grid-cols-2 gap-3 lg:grid-cols-4 xl:min-w-[680px]">
                <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-3">
                    <p class="text-xs text-secondary">saldo atual</p>
                    <strong class="mt-1 block text-xl font-semibold text-[var(--dark)]">{{ summary.current_balance_label }}</strong>
                </div>
                <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-3">
                    <p class="text-xs text-secondary">saldo do ciclo</p>
                    <strong class="mt-1 block text-xl font-semibold text-primary">{{ summary.cycle_balance_label }}</strong>
                </div>
                <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-3">
                    <p class="text-xs text-secondary">proximo recebimento</p>
                    <strong class="mt-1 block text-xl font-semibold text-[var(--dark)]">{{ summary.next_income_label }}</strong>
                </div>
                <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-3">
                    <p class="text-xs text-secondary">comprometido</p>
                    <strong class="mt-1 block text-xl font-semibold text-purple">{{ summary.committed_label }}</strong>
                </div>
            </div>
        </div>

        <div class="mt-5 grid gap-3 md:grid-cols-[1fr_auto] md:items-center">
            <div>
                <div class="flex items-center justify-between text-xs">
                    <span class="text-secondary">progresso do ciclo 20 jun - 05 jul</span>
                    <span class="text-purple">62% planejado</span>
                </div>
                <div class="mt-2 h-2 overflow-hidden rounded-full bg-[var(--yellow)]">
                    <div class="h-full w-[62%] rounded-full bg-[var(--lilac)]"></div>
                </div>
            </div>

            <div class="flex rounded bg-[var(--yellow)] p-1 text-xs text-primary">
                <button class="rounded bg-[var(--lilac)] px-3 py-1 font-semibold text-light">ciclo</button>
                <button class="rounded px-3 py-1">data</button>
                <button class="rounded px-3 py-1">categoria</button>
                <button class="rounded px-3 py-1">wallet</button>
            </div>
        </div>
    </section>

    <section class="mt-8 grid grid-cols-1 gap-8 2xl:grid-cols-[minmax(0,1fr)_320px]">
        <div class="space-y-6">
            <article class="relative rounded border border-[var(--yellow)] bg-[#fffff5] p-5">
                <div class="absolute bottom-5 left-8 top-20 w-px bg-[var(--yellow)]"></div>

                <header class="grid gap-4 md:grid-cols-[auto_1fr_auto] md:items-center">
                    <div class="flex h-14 w-14 items-center justify-center rounded-full bg-[var(--yellow)] text-primary">
                        <span class="text-lg font-semibold">20</span>
                    </div>
                    <div>
                        <h2 class="text-xl font-semibold text-primary">20 jun - 05 jul</h2>
                        <p class="mt-1 text-sm opacity-70">ciclo atual ate o proximo recebimento</p>
                    </div>
                    <div class="grid grid-cols-3 gap-3 text-right text-xs md:min-w-[360px]">
                        <div>
                            <p class="text-secondary">recebe</p>
                            <strong class="block text-sm text-primary">+R$ 1.500</strong>
                        </div>
                        <div>
                            <p class="text-secondary">gastos</p>
                            <strong class="block text-sm text-purple">-R$ 680</strong>
                        </div>
                        <div>
                            <p class="text-secondary">sobra</p>
                            <strong class="block text-sm text-[var(--dark)]">R$ 820</strong>
                        </div>
                    </div>
                </header>

                <div class="mt-5 space-y-3 pl-0 md:pl-20">
                    <div class="grid gap-3 rounded border border-[var(--yellow)] bg-[var(--light)] p-3 sm:grid-cols-[1fr_auto] sm:items-center">
                        <div class="flex items-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary text-light">
                                <i class="fa-solid fa-burger"></i>
                            </div>
                            <div>
                                <h3 class="font-medium">Mercado da semana</h3>
                                <p class="text-xs text-secondary">alimentacao • carteira principal</p>
                            </div>
                        </div>
                        <div class="flex items-center justify-between gap-4 sm:block sm:text-right">
                            <span class="text-xs text-secondary">24 jun</span>
                            <strong class="block text-sm">R$ 180,00</strong>
                            <span class="badge">pendente</span>
                        </div>
                    </div>

                    <div class="grid gap-3 rounded border border-[var(--yellow)] bg-[var(--light)] p-3 sm:grid-cols-[1fr_auto] sm:items-center">
                        <div class="flex items-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--yellow)] text-primary">
                                <i class="fa-solid fa-tv"></i>
                            </div>
                            <div>
                                <h3 class="font-medium">Netflix</h3>
                                <p class="text-xs text-secondary">assinaturas • cartao credito</p>
                            </div>
                        </div>
                        <div class="flex items-center justify-between gap-4 sm:block sm:text-right">
                            <span class="text-xs text-secondary">28 jun</span>
                            <strong class="block text-sm">R$ 55,00</strong>
                            <span class="badge">pendente</span>
                        </div>
                    </div>

                    <div class="grid gap-3 rounded border border-[var(--yellow)] bg-[var(--light)] p-3 opacity-80 sm:grid-cols-[1fr_auto] sm:items-center">
                        <div class="flex items-center gap-3">
                            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--lilac)] text-light">
                                <i class="fa-solid fa-dumbbell"></i>
                            </div>
                            <div>
                                <h3 class="font-medium">Academia</h3>
                                <p class="text-xs text-secondary">saude • debito automatico</p>
                            </div>
                        </div>
                        <div class="flex items-center justify-between gap-4 sm:block sm:text-right">
                            <span class="text-xs text-secondary">02 jul</span>
                            <strong class="block text-sm">R$ 120,00</strong>
                            <span class="badge">pago</span>
                        </div>
                    </div>
                </div>
            </article>

            <article class="relative rounded border border-[var(--yellow)] bg-[#fffff5] p-5">
                <header class="grid gap-4 md:grid-cols-[auto_1fr_auto] md:items-center">
                    <div class="flex h-14 w-14 items-center justify-center rounded-full bg-[var(--yellow)] text-primary">
                        <span class="text-lg font-semibold">05</span>
                    </div>
                    <div>
                        <h2 class="text-xl font-semibold text-primary">05 jul - 20 jul</h2>
                        <p class="mt-1 text-sm opacity-70">proximo ciclo projetado</p>
                    </div>
                    <div class="grid grid-cols-3 gap-3 text-right text-xs md:min-w-[360px]">
                        <div>
                            <p class="text-secondary">recebe</p>
                            <strong class="block text-sm text-primary">+R$ 2.200</strong>
                        </div>
                        <div>
                            <p class="text-secondary">gastos</p>
                            <strong class="block text-sm text-purple">-R$ 1.100</strong>
                        </div>
                        <div>
                            <p class="text-secondary">sobra</p>
                            <strong class="block text-sm text-[var(--dark)]">R$ 1.100</strong>
                        </div>
                    </div>
                </header>

                <div class="mt-5 grid gap-3 md:grid-cols-2">
                    <div class="rounded border border-[var(--yellow)] bg-[var(--light)] p-3">
                        <p class="text-xs text-secondary">maior impacto</p>
                        <h3 class="mt-1 font-medium">Parcela do cartao</h3>
                        <p class="mt-2 text-sm">R$ 740,00 previstos para 08 jul.</p>
                    </div>
                    <div class="rounded border border-[var(--yellow)] bg-[var(--light)] p-3">
                        <p class="text-xs text-secondary">ponto de atencao</p>
                        <h3 class="mt-1 font-medium">saldo fica apertado ate dia 12</h3>
                        <p class="mt-2 text-sm">Evite gastos acima de R$ 220 antes desse marco.</p>
                    </div>
                </div>
            </article>
        </div>

        <aside class="space-y-4 2xl:min-w-[320px]">
            <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-4">
                <p class="text-xs text-secondary">voce pode gastar hoje</p>
                <strong class="mt-2 block text-3xl font-semibold text-primary md:text-4xl">R$ 320</strong>
                <p class="mt-2 max-w-[260px] text-sm leading-relaxed opacity-75">sem comprometer contas previstas antes do proximo recebimento.</p>
            </div>

            <div class="rounded border border-[var(--yellow)] bg-[#fffff5] p-4">
                <h2 class="font-semibold text-primary">proximos marcos</h2>
                <div class="mt-4 space-y-3">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <p class="text-sm font-medium">Mercado</p>
                            <p class="text-xs text-secondary">24 jun</p>
                        </div>
                        <strong class="text-sm">R$ 180</strong>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <p class="text-sm font-medium">Netflix</p>
                            <p class="text-xs text-secondary">28 jun</p>
                        </div>
                        <strong class="text-sm">R$ 55</strong>
                    </div>
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <p class="text-sm font-medium">Salario</p>
                            <p class="text-xs text-secondary">05 jul</p>
                        </div>
                        <strong class="text-sm text-primary">+R$ 2.200</strong>
                    </div>
                </div>
            </div>

            <button type="button" class="btn-primary fixed bottom-20 right-6 flex h-12 w-12 items-center justify-center rounded-full text-xl shadow-lg md:hidden" data-open-transaction-modal aria-label="Novo registro">
                <i class="fa-solid fa-plus"></i>
            </button>
        </aside>
    </section>
{% endblock %}
