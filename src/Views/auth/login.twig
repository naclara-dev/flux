{% extends 'layouts/app.twig' %}
{% set show_menu = false %}
{% set no_padding = true %}

{% block sidebar %}{% endblock %}

{% block content %}
    <section class="flex min-h-screen w-full">
        <article class="hidden md:flex flex-1 flex-col justify-center p-8 bg-primary bg-pattern rounded-md">
            <p class="text-purple text-4xl font-bold">
                oi :)
            </p>
            <div class="flex gap-3">
                <p class="text-light text-4xl">
                    bem-vindo ao
                </p>
                <img src="{{ base_url }}/assets/img/logo-light.svg" alt="Flux" class="w-20">
            </div>

            <p class="text-light mt-4 text-xl">
                seu app de gestão de gastos inteligente.
            </p>
        </article>
        <article class="auth-column flex-1 flex flex-col justify-center items-center p-8">
            <nav class="tab-menu" aria-label="Alternar entre login e cadastro">
                <a href="#" class="tab-item active" data-tab-target="login-form" aria-controls="login-form" aria-selected="true">
                    já tenho conta
                </a>
                <a href="#" class="tab-item" data-tab-target="register-form" aria-controls="register-form" aria-selected="false">
                    criar uma conta
                </a>
            </nav>

            <img src="{{ base_url }}/assets/img/logo.svg" alt="Flux" class="w-25 auth-logo">

            <div class="tab-stage w-100 mt-5">
                <form action="{{ base_url }}/login/" method="post" id="login-form" class="tab is-active validate w-100">
                    {% if login_error|default('') %}
                        <p class="mb-4 rounded border border-[var(--yellow)] bg-[#fffff5] px-3 py-2 text-sm text-primary">
                            {{ login_error }}
                        </p>
                    {% endif %}

                    <div class="form-group w-100">
                        <label for="email">e-mail</label>
                        <input id="email" name="email" autocomplete="username" class="w-100" type="text" data-type="required|email|exists" data-exists-url="{{ base_url }}/login/check-email/">
                    </div>
                    <div class="form-group w-100 mt-4">
                        <label for="password">senha</label>
                        <input id="password" name="password" autocomplete="current-password" class="w-100" type="password" data-type="required">
                    </div>
                    <button type="submit" class="btn-secondary mt-4 w-100 font-bold">
                        <i class="fa-solid fa-arrow-right-to-bracket mr-2"></i>
                        entrar
                    </button>

                    <a href="{{ base_url }}/login/google/" class="mt-3 flex w-100 items-center justify-center rounded border border-[var(--yellow)] bg-[#fffff5] px-3 py-2 font-bold text-primary transition hover:bg-[var(--yellow)]">
                        <i class="fa-brands fa-google mr-2"></i>
                        entrar com google
                    </a>
                </form>

                <form action="{{ base_url }}/register/" method="post" id="register-form" class="tab is-after validate w-100" hidden>
                    <div class="form-group w-100">
                        <label for="register-name">nome</label>
                        <input id="register-name" name="name" class="w-100" type="text" data-type="required">
                    </div>
                    <div class="form-group w-100 mt-4">
                        <label for="register-email">e-mail</label>
                        <input id="register-email" name="email" type="email" autocomplete="username" class="w-100" data-type="required|email|unique" data-unique-url="{{ base_url }}/register/check-email/">
                    </div>
                    <div class="form-group w-100 mt-4">
                        <label for="register-password">senha</label>
                        <input id="register-password" name="password" autocomplete="new-password" class="w-100" type="password" data-type="required">
                    </div>
                    <button type="submit" class="btn-secondary mt-4 w-100 font-bold">
                        <i class="fa-solid fa-user-plus mr-2"></i>
                        criar conta
                    </button>
                </form>
            </div>
        </article>
    </section>
{% endblock %}

{% block scripts %}
    <script src="{{ base_url }}/assets/js/auth-tabs.js"></script>
{% endblock %}
