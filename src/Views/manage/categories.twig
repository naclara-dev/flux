{% extends 'layouts/app.twig' %}

{% block content %}
    <section class="grid grid-cols-1 md:grid-cols-2 items-end">
        <div>
            <div class="flex items-center gap-2">
                <h1 class="text-primary text-3xl">
                    categorias
                </h1>
                {# Define a dica contextual da tela de categorias #}
                <div class="info-hint-wrapper" data-info-hint>
                    <button type="button" class="flex h-7 w-7 items-center justify-center rounded text-secondary transition hover:text-[var(--lilac)] focus-visible:bg-[var(--lilac)] focus-visible:outline-none" aria-label="Mostrar explicação sobre categorias" aria-describedby="categories-info-hint" aria-expanded="false" data-info-hint-toggle>
                        <i class="fa-regular fa-circle-question"></i>
                    </button>
                    <div id="categories-info-hint" class="info-hint" role="tooltip">
                        grupos para organizar as movimentações financeiras. ajudam a identificar origem, destino e finalidade.
                    </div>
                </div>
            </div>
            <p class="text-sm mt-2">
                organize seus lançamentos em categorias personalizadas.
            </p>
        </div> 
        <div class="flex justify-end"> 
            <button type="button" class="modal-toggle btn-primary w-50 mt-4 text-xl" data-modal-target="#category-modal">
                <i class="fa-solid fa-plus fa-sm mr-1"></i>
                criar
            </button>
        </div> 
    </section>

    <section class="mt-10 grid grid-cols-1 gap-4 md:grid-cols-4">
        {% for category in categories %}
            <div class="manage-card relative w-full">
                <button type="button" class="w-full pr-10 text-left" data-edit-category data-category-id="{{ category.id|e('html_attr') }}" data-category-name="{{ category.name|e('html_attr') }}" data-category-color="{{ category.color|e('html_attr') }}" data-category-icon="{{ category.icon|e('html_attr') }}">
                    <div class="flex items-center gap-3">
                        <div class="flex h-9 w-9 flex-none items-center justify-center rounded-full text-light" style="background-color: {{ category.color|e('html_attr') }}">
                            {% if category.icon %}
                                <i class="{{ category.icon|e('html_attr') }}"></i>
                            {% endif %}
                        </div>
                        <div class="manage-card-text">                
                            {{ category.name }}            
                        </div>
                    </div>
                </button>

                <form method="post" action="{{ base_url }}/manage/categories/delete" class="absolute right-2 top-3">
                    <input type="hidden" name="id" value="{{ category.id|e('html_attr') }}">
                    <button type="submit" class="cursor-pointer flex h-8 w-8 items-center justify-center rounded text-secondary" aria-label="Excluir Categoria" data-delete-button>
                        <i class="fa-regular fa-trash-can"></i>
                    </button>
                </form>
            </div>
        {% else %} 
            <p class="col-span-4 flex min-h-[calc(100vh-220px)] items-center justify-center text-center text-secondary text-3xl">
                você ainda não cadastrou nenhuma categoria :/ 
            </p>              
        {% endfor %}  
    </section>

    <dialog id="category-modal" class="modal fixed top-1/2 left-1/2 w-[min(92vw,650px)] -translate-x-1/2 -translate-y-1/2 scale-95 rounded-lg border border-[var(--yellow)] bg-[#fffff5] p-0 text-[var(--dark)] opacity-0 shadow-xl transition duration-200 backdrop:bg-[rgba(58,56,53,0.35)]" data-category-modal data-icons-url="{{ base_url }}/assets/vendor/fontawesome/icons.json">
        <form method="post" action="{{ base_url }}/manage/categories/store" class="validate" data-category-form>
            <div class="flex items-center justify-between px-6 py-4">
                <div>
                    <h2 class="text-xl font-medium text-primary font-bold" data-category-modal-title>nova categoria</h2>
                    <p class="mt-1 text-xs text-[var(--dark)] opacity-70">escolha nome, cor e ícone.</p>
                </div>
                <button type="button" class="modal-close flex h-9 w-9 items-center justify-center rounded text-primary transition hover:bg-[var(--yellow)]" aria-label="Fechar">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="space-y-5 px-6 py-5">
                <input type="hidden" name="id" data-category-id-input>

                <div class="form-group">
                    <label for="category-name">nome</label>
                    <input id="category-name" name="name" type="text" data-type="required" class="mt-1 w-full bg-transparent outline-none" autocomplete="off" data-category-name-input>
                </div>

                <div class="grid grid-cols-1 gap-4 sm:grid-cols-[120px_1fr]">
                    <div class="form-group">
                        <label for="category-color">cor</label>
                        <input id="category-color" name="color" type="color" value="#c17fd7" data-type="required" class="mt-2 h-10 w-24 cursor-pointer bg-transparent p-1" data-category-color-input>
                    </div>

                    <div class="form-group">
                        <label>ícone</label>
                        <input type="hidden" name="icon" data-category-icon-input>

                        <button type="button" class="h-10 border-b-[1.5px] border-[var(--lilac)] mt-2 flex w-full items-center justify-between rounded text-left transition" data-toggle-icon-picker>
                            <span class="flex items-center gap-3">
                                <span class="flex h-9 w-9 items-center justify-center rounded text-primary" data-selected-icon-preview>
                                    <i class="fa-solid fa-icons"></i>
                                </span>
                                <span data-selected-icon-label class="text-sm">
                                    escolha um ícone
                                </span>
                            </span>
                            <i class="fa-solid fa-chevron-down text-primary"></i>
                        </button>
                    </div>
                </div>

                <div class="hidden rounded border border-[var(--yellow)] bg-[var(--light)] p-3" data-icon-picker>
                    <div class="form-group mb-3">
                        <label for="category-icon-search">Buscar ícone</label>
                        <input id="category-icon-search" type="search" class="mt-1 w-full bg-transparent outline-none" placeholder="Ex.: casa, carro, mercado" data-icon-search>
                    </div>

                    <div class="grid max-h-64 grid-cols-4 gap-2 overflow-y-auto pr-1 sm:grid-cols-6 md:grid-cols-8" data-icon-grid></div>
                </div>
            </div>

            <div class="flex justify-end gap-3 px-6 py-4">
                <button type="button" class="modal-close btn-secondary">
                    cancelar
                </button>
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-check"></i> 
                    salvar
                </button>
            </div>
        </form>
    </dialog>
{% endblock %}

{% block scripts %}
    <script src="{{ base_url }}/assets/js/categories.js"></script>
{% endblock %}
