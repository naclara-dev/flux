{% extends 'layouts/app.twig' %}

{% block content %}    
    <section class="grid grid-cols-1 md:grid-cols-2 items-end">
        <div>
            <div class="flex items-center gap-2">
                <h1 class="text-primary text-3xl">
                    cadastros
                </h1>
                {# Define a dica contextual da tela de cadastros #}
                <div class="info-hint-wrapper" data-info-hint>
                    <button type="button" class="flex h-7 w-7 items-center justify-center rounded text-secondary transition hover:text-[var(--lilac)] focus-visible:bg-[var(--lilac)] focus-visible:outline-none" aria-label="Mostrar explicação sobre cadastros" aria-describedby="manage-info-hint" aria-expanded="false" data-info-hint-toggle>
                        <i class="fa-regular fa-circle-question"></i>
                    </button>
                    <div id="manage-info-hint" class="info-hint" role="tooltip">
                        atalhos para cadastrar as bases do Flux.
                        categorias, wallets, entidades e templates alimentam os lançamentos e ciclos financeiros.
                    </div>
                </div>
            </div>
            <p class="text-sm mt-2">
                crie e gerencie todas as informações essenciais do Flux.
            </p>
        </div>  
    </section>

    <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-10">
        <a class="manage-card" href="{{ base_url }}/manage/categories">
            <div class="manage-card-icon">
                <i class="fa-regular fa-note-sticky fa-xl"></i>            
            </div>
            <div class="manage-card-content">
                <div class="manage-card-title">                
                    categorias            
                </div> 
                <div class="manage-card-text">
                    organize seus lançamentos em categorias personalizadas.
                </div> 
                <div class="manage-card-info">
                    <span class="badge">
                        {{ categories_count }}
                        categorias
                    </span>
                </div> 
            </div>       
        </a> 
        <a class="manage-card" href="{{ base_url }}/manage/wallets">
            <div class="manage-card-icon">
                <i class="fa-regular fa-envelope fa-xl"></i>
            </div>
            <div class="manage-card-content">
                <div class="manage-card-title">                
                    wallets            
                </div> 
                <div class="manage-card-text">
                    crie e gerencie suas contas financeiras e fontes de saldo.
                </div> 
                <div class="manage-card-info">
                    <span class="badge">
                        {{ wallets_count }}
                        wallets
                    </span>
                </div> 
            </div>       
        </a> 
        <a class="manage-card" href="{{ base_url }}/manage/entities">
            <div class="manage-card-icon">
                <i class="fa-regular fa-user fa-xl"></i>
            </div>
            <div class="manage-card-content">
                <div class="manage-card-title">                
                    entidades            
                </div> 
                <div class="manage-card-text">
                    crie e gerencie pessoas, grupos e organizações credoras.
                </div> 
                <div class="manage-card-info">
                    <span class="badge">
                        {{ entities_count }}
                        entidades
                    </span>
                </div> 
            </div>       
        </a> 
        <a class="manage-card" href="{{ base_url }}/manage/templates">
            <div class="manage-card-icon">
                <i class="fa-regular fa-file-lines fa-xl"></i>           
            </div>
            <div class="manage-card-content">
                <div class="manage-card-title">                
                    templates            
                </div> 
                <div class="manage-card-text">
                    defina modelos personalizados para lançamentos periódicos.
                </div> 
                <div class="manage-card-info">
                    <span class="badge">
                        {{ templates_count }}
                        templates
                    </span>
                </div> 
            </div>       
        </a>          
    </section> 
{% endblock %}
