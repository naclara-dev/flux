{% extends 'layouts/app.twig' %}

{% block content %}
    <section class="grid grid-cols-1 md:grid-cols-2 items-end">
        <div>
            <h1 class="text-primary text-3xl">
                ajustes
            </h1>
            <p class="text-sm mt-2">
                gerencie suas preferências e opções dentro do Flux.
            </p>
        </div>
    </section>

    <section class="mt-10 grid grid-cols-1 gap-4 md:grid-cols-3">
        <button type="button" class="modal-toggle manage-card w-full text-left" data-modal-target="#transaction-settings-modal">
            <div class="manage-card-icon">
                <i class="fa-solid fa-gears fa-xl"></i>
            </div>
            <div class="manage-card-content">
                <div class="manage-card-title">
                    transa&ccedil;&otilde;es
                </div>
                <div class="manage-card-text">
                    defina valores padr&atilde;o ao cadastrar lan&ccedil;amentos.
                </div>
            </div>
        </button>

        <button type="button" class="modal-toggle manage-card w-full text-left" data-modal-target="#cycle-settings-modal">
            <div class="manage-card-icon">
                <i class="fa-solid fa-arrows-spin fa-xl"></i>
            </div>
            <div class="manage-card-content">
                <div class="manage-card-title">
                    ciclos financeiros
                </div>
                <div class="manage-card-text">
                    defina como recebimentos abrem ou fecham ciclos.
                </div>
            </div>
        </button>

        <button type="button" class="modal-toggle manage-card w-full text-left" data-modal-target="#account-settings-modal">
            <div class="manage-card-icon">
                <i class="fa-regular fa-user fa-xl"></i>
            </div>
            <div class="manage-card-content">
                <div class="manage-card-title">
                    minha conta
                </div>
                <div class="manage-card-text">
                    gerencie seus dados pessoais.
                </div>
            </div>
        </button>
    </section>

    <!-- Configurações de Transação -->
    <dialog id="transaction-settings-modal" class="modal fixed top-1/2 left-1/2 w-[min(92vw,650px)] -translate-x-1/2 -translate-y-1/2 scale-95 rounded-lg border border-[var(--yellow)] bg-[#fffff5] p-0 text-[var(--dark)] opacity-0 shadow-xl transition duration-200 backdrop:bg-[rgba(58,56,53,0.35)]">
        <form method="post" action="{{ base_url }}/settings/store" class="validate" data-settings-form>
            <div class="flex items-center justify-between px-6 py-4">
                <div>
                    <h2 class="text-xl font-bold text-primary">configura&ccedil;&otilde;es de transa&ccedil;&otilde;es</h2>
                    <p class="mt-1 text-xs text-[var(--dark)] opacity-70">defina os campos padr&atilde;o para novos lan&ccedil;amentos.</p>
                </div>
                <button type="button" class="modal-close flex h-9 w-9 items-center justify-center rounded text-primary transition hover:bg-[var(--yellow)]" aria-label="Fechar">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="space-y-5 px-6 py-5">
                <input type="hidden" name="id" value="{{ settings.id|default('')|e('html_attr') }}">

                {# Declara o combobox do tipo padrão #}
                <div class="form-group" data-select data-select-name="default-type" data-select-placeholder="escolha o tipo">
                    <label>tipo padr&atilde;o</label>
                    <input type="hidden" name="default_type" value="{{ settings.default_type|default('')|e('html_attr') }}" data-select-input>

                    <button type="button" class="mt-1 flex h-[29px] w-full items-center justify-between rounded border-b-[1.5px] border-[var(--lilac)] bg-transparent px-[7px] py-[3px] text-left leading-[21px] transition hover:border-[var(--purple)]" data-select-toggle aria-expanded="false">
                        <span class="text-sm" data-select-label>
                            escolha o tipo
                        </span>
                        <i class="fa-solid fa-chevron-down text-primary"></i>
                    </button>

                    <div class="mt-2 max-h-0 overflow-hidden rounded border border-transparent bg-[#fffff5] opacity-0 shadow-lg transition-all duration-200" data-select-menu>
                        <button type="button" class="flex w-full items-center rounded px-3 py-2 text-left text-sm transition hover:bg-[var(--yellow)] hover:text-primary" data-select-option data-value="E" data-value-label="despesa" aria-selected="false">
                            despesa
                        </button>
                        <button type="button" class="flex w-full items-center rounded px-3 py-2 text-left text-sm transition hover:bg-[var(--yellow)] hover:text-primary" data-select-option data-value="I" data-value-label="receita" aria-selected="false">
                            receita
                        </button>
                    </div>
                </div>

                {# Declara o combobox da forma de pagamento padrão #}
                <div class="form-group" data-select data-select-name="payment-method" data-select-placeholder="escolha uma forma">
                    <label>forma de pagamento padr&atilde;o</label>
                    <input type="hidden" name="default_payment_method_id" value="{{ settings.default_payment_method_id|default('')|e('html_attr') }}" data-select-input>

                    <button type="button" class="mt-1 flex h-[29px] w-full items-center justify-between rounded border-b-[1.5px] border-[var(--lilac)] bg-transparent px-[7px] py-[3px] text-left leading-[21px] transition hover:border-[var(--purple)]" data-select-toggle aria-expanded="false">
                        <span class="text-sm" data-select-label>
                            escolha uma forma
                        </span>
                        <i class="fa-solid fa-chevron-down text-primary"></i>
                    </button>

                    <div class="mt-2 max-h-0 overflow-hidden rounded border border-transparent bg-[#fffff5] opacity-0 shadow-lg transition-all duration-200" data-select-menu>
                        {% for method in payment_methods %}
                            <button type="button" class="flex w-full items-center rounded px-3 py-2 text-left text-sm transition hover:bg-[var(--yellow)] hover:text-primary" data-select-option data-value="{{ method.id|e('html_attr') }}" data-value-label="{{ method.name|e('html_attr') }}" aria-selected="false">
                                {{ method.name }}
                            </button>
                        {% endfor %}
                    </div>
                </div>

                {# Declara o combobox da wallet padrão #}
                <div class="form-group" data-select data-select-name="wallet" data-select-placeholder="escolha uma wallet">
                    <label>wallet padr&atilde;o</label>
                    <input type="hidden" name="default_wallet_id" value="{{ settings.default_wallet_id|default('')|e('html_attr') }}" data-select-input>

                    <button type="button" class="mt-1 flex h-[29px] w-full items-center justify-between rounded border-b-[1.5px] border-[var(--lilac)] bg-transparent px-[7px] py-[3px] text-left leading-[21px] transition hover:border-[var(--purple)]" data-select-toggle aria-expanded="false">
                        <span class="text-sm" data-select-label>
                            escolha uma wallet
                        </span>
                        <i class="fa-solid fa-chevron-down text-primary"></i>
                    </button>

                    <div class="mt-2 max-h-0 overflow-hidden rounded border border-transparent bg-[#fffff5] opacity-0 shadow-lg transition-all duration-200" data-select-menu>
                        {% for wallet in wallets %}
                            <button type="button" class="flex w-full items-center rounded px-3 py-2 text-left text-sm transition hover:bg-[var(--yellow)] hover:text-primary" data-select-option data-value="{{ wallet.id|e('html_attr') }}" data-value-label="{{ wallet.name|e('html_attr') }}" aria-selected="false">
                                {{ wallet.name }}
                            </button>
                        {% endfor %}
                    </div>
                </div>

                {# Declara o combobox da entidade padrão #}
                <div class="form-group" data-select data-select-name="entity" data-select-placeholder="escolha uma entidade">
                    <label>entidade padr&atilde;o</label>
                    <input type="hidden" name="default_entity_id" value="{{ settings.default_entity_id|default('')|e('html_attr') }}" data-select-input>

                    <button type="button" class="mt-1 flex h-[29px] w-full items-center justify-between rounded border-b-[1.5px] border-[var(--lilac)] bg-transparent px-[7px] py-[3px] text-left leading-[21px] transition hover:border-[var(--purple)]" data-select-toggle aria-expanded="false">
                        <span class="text-sm" data-select-label>
                            escolha uma entidade
                        </span>
                        <i class="fa-solid fa-chevron-down text-primary"></i>
                    </button>

                    <div class="mt-2 max-h-0 overflow-hidden rounded border border-transparent bg-[#fffff5] opacity-0 shadow-lg transition-all duration-200" data-select-menu>
                        {% for entity in entities %}
                            <button type="button" class="flex w-full items-center rounded px-3 py-2 text-left text-sm transition hover:bg-[var(--yellow)] hover:text-primary" data-select-option data-value="{{ entity.id|e('html_attr') }}" data-value-label="{{ entity.name|e('html_attr') }}" aria-selected="false">
                                {{ entity.name }}
                            </button>
                        {% endfor %}
                    </div>
                </div>

            </div>

            <div class="flex justify-end gap-3 px-6 py-4">
                <button type="button" class="modal-close btn-secondary">
                    cancelar
                </button>
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-check"></i>
                    salvar
                </button>
            </div>
        </form>
    </dialog>

    <!-- Configurações de Ciclo Financeiro -->
    <dialog id="cycle-settings-modal" class="modal fixed top-1/2 left-1/2 w-[min(92vw,560px)] -translate-x-1/2 -translate-y-1/2 scale-95 rounded-lg border border-[var(--yellow)] bg-[#fffff5] p-0 text-[var(--dark)] opacity-0 shadow-xl transition duration-200 backdrop:bg-[rgba(58,56,53,0.35)]">
        <form method="post" action="{{ base_url }}/settings/store" class="validate">
            <div class="flex items-center justify-between px-6 py-4">
                <div>
                    <h2 class="text-xl font-bold text-primary">ciclos financeiros</h2>
                    <p class="mt-1 text-xs text-[var(--dark)] opacity-70">defina como os recebimentos delimitam seus ciclos.</p>
                </div>
                <button type="button" class="modal-close flex h-9 w-9 items-center justify-center rounded text-primary transition hover:bg-[var(--yellow)]" aria-label="Fechar">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="space-y-5 px-6 py-5">
                <input type="hidden" name="id" value="{{ settings.id|default('')|e('html_attr') }}">

                <label class="flex cursor-pointer items-start gap-3 text-sm text-[var(--dark)]">
                    <input type="hidden" name="cycle_starts_after_income" value="0">
                    <input type="checkbox" name="cycle_starts_after_income" value="1" class="peer sr-only" {% if settings.cycle_starts_after_income|default(1) %}checked{% endif %}>
                    <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded border-[1.5px] border-[var(--lilac)] text-[0px] text-light transition peer-checked:bg-[var(--lilac)] peer-checked:text-xs">
                        <i class="fa-solid fa-check"></i>
                    </span>
                    <span>
                        iniciar fluxo no dia posterior ao recebimento
                        <small class="mt-1 block text-xs text-[var(--dark)] opacity-60">quando ativo, o recebimento fecha o ciclo atual.</small>
                    </span>
                </label>
            </div>

            <div class="flex justify-end gap-3 px-6 py-4">
                <button type="button" class="modal-close btn-secondary">
                    cancelar
                </button>
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-check"></i>
                    salvar
                </button>
            </div>
        </form>
    </dialog>

    <!-- Configurações de Conta -->
    <dialog id="account-settings-modal" class="modal fixed top-1/2 left-1/2 max-h-[90vh] w-[min(92vw,560px)] -translate-x-1/2 -translate-y-1/2 scale-95 overflow-y-auto rounded-lg border border-[var(--yellow)] bg-[#fffff5] p-0 text-[var(--dark)] opacity-0 shadow-xl transition duration-200 backdrop:bg-[rgba(58,56,53,0.35)]" {% if account_feedback|default(null) %}data-account-feedback data-expand-password="{{ account_feedback.change_password ? '1' : '0' }}"{% endif %}>
        <form method="post" action="{{ base_url }}/account/update/" class="validate">
            <div class="flex items-center justify-between px-6 py-4">
                <div>
                    <h2 class="text-xl font-bold text-primary">minha conta</h2>
                    <p class="mt-1 text-xs text-[var(--dark)] opacity-70">gerencie seus dados pessoais.</p>
                </div>
                <button type="button" class="modal-close flex h-9 w-9 items-center justify-center rounded text-primary transition hover:bg-[var(--yellow)]" aria-label="Fechar">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="space-y-5 px-6 py-5">
                <input type="hidden" name="id" value="{{ user.id }}">

                {# Exibe o feedback temporário da atualização da conta #}
                {% if account_feedback|default(null) %}
                    <div class="flex items-start gap-3 rounded border px-3 py-3 text-sm {% if account_feedback.type == 'success' %}border-[var(--lilac)] bg-[rgba(193,127,215,0.08)] text-primary{% else %}border-[var(--yellow)] bg-[var(--light)] text-[var(--purple)]{% endif %}" role="alert">
                        <i class="fa-solid {% if account_feedback.type == 'success' %}fa-circle-check{% else %}fa-circle-exclamation{% endif %} mt-0.5"></i>
                        <span>{{ account_feedback.message }}</span>
                    </div>
                {% endif %}

                <div class="form-group">
                    <label for="name">nome</label>
                    <input name="name" id="name" class="w-full" type="text" value="{{ user.name }}" data-type="required">
                </div>
                <div class="form-group">
                    <label for="email">e-mail</label>
                    <input name="email" id="email" class="w-full" type="text" value="{{ user.email }}" data-type="required" readonly>
                </div> 
            </div>

            <div class="flex justify-end gap-3 px-6 py-4">
                <button type="button" class="modal-close btn-secondary">
                    cancelar
                </button>
                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-check"></i>
                    salvar
                </button>
            </div>
        </form>
    </dialog>
{% endblock %}

{% block scripts %}
    <script src="{{ base_url }}/assets/js/settings.js"></script>
{% endblock %}
