<dialog class="fixed top-1/2 left-1/2 w-[min(92vw,760px)] -translate-x-1/2 -translate-y-1/2 scale-95 rounded-lg border border-[var(--yellow)] bg-[#fffff5] p-0 text-[var(--dark)] opacity-0 shadow-xl transition duration-200 backdrop:bg-[rgba(58,56,53,0.35)]" data-transaction-modal>
    <form method="post" action="{{ base_url }}/transactions/store" class="validate" data-transaction-form>
        <div class="flex items-center justify-between px-6 py-4">
            <div>
                <h2 class="text-xl font-bold text-primary" data-transaction-modal-title>novo registro</h2>
                <p class="mt-1 text-xs text-[var(--dark)] opacity-70">registre uma movimentacao financeira.</p>
            </div>
            <button type="button" class="flex h-9 w-9 items-center justify-center rounded text-primary transition hover:bg-[var(--yellow)]" data-close-transaction-modal aria-label="Fechar">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="space-y-5 px-6 py-5">
            <input type="hidden" name="id">

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-[1fr_160px]">
                <div class="form-group">
                    <label for="transaction-title">titulo</label>
                    <input id="transaction-title" name="title" type="text" data-type="required" class="mt-1 w-full bg-transparent outline-none" autocomplete="off">
                </div>

                <div class="form-group">
                    <label for="transaction-amount">valor</label>
                    <input id="transaction-amount" name="amount" type="text" inputmode="decimal" value="0,00" data-type="required" class="mt-1 h-[29px] w-full bg-transparent leading-[21px] outline-none" autocomplete="off">
                </div>
            </div>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                <div class="form-group">
                    <label>wallet</label>
                    <input type="hidden" name="wallet_id" data-type="required" data-transaction-wallet-input>
                    <button type="button" class="mt-1 flex h-[29px] w-full items-center justify-between rounded border-b-[1.5px] border-[var(--lilac)] bg-transparent px-[7px] py-[3px] text-left leading-[21px] transition hover:border-[var(--purple)]" data-transaction-select-toggle="wallet">
                        <span data-transaction-wallet-label class="text-sm">escolha uma wallet</span>
                        <i class="fa-solid fa-chevron-down text-primary"></i>
                    </button>
                    <div class="mt-2 max-h-0 overflow-hidden rounded border border-transparent bg-[#fffff5] opacity-0 shadow-lg transition-all duration-200" data-transaction-select-menu="wallet">
                        {% for wallet in transaction_wallets|default([]) %}
                            <button type="button" class="flex w-full items-center rounded px-3 py-2 text-left text-sm transition hover:bg-[var(--yellow)] hover:text-primary" data-transaction-option="wallet" data-transaction-option-id="{{ wallet.id|e('html_attr') }}" data-transaction-option-name="{{ wallet.name|e('html_attr') }}">
                                {{ wallet.name }}
                            </button>
                        {% endfor %}
                    </div>
                </div>

                <div class="form-group">
                    <label>categoria</label>
                    <input type="hidden" name="category_id" data-transaction-category-input>
                    <button type="button" class="mt-1 flex h-[29px] w-full items-center justify-between rounded border-b-[1.5px] border-[var(--lilac)] bg-transparent px-[7px] py-[3px] text-left leading-[21px] transition hover:border-[var(--purple)]" data-transaction-select-toggle="category">
                        <span data-transaction-category-label class="text-sm">escolha uma categoria</span>
                        <i class="fa-solid fa-chevron-down text-primary"></i>
                    </button>
                    <div class="mt-2 max-h-0 overflow-hidden rounded border border-transparent bg-[#fffff5] opacity-0 shadow-lg transition-all duration-200" data-transaction-select-menu="category">
                        {% for category in transaction_categories|default([]) %}
                            <button type="button" class="flex w-full items-center rounded px-3 py-2 text-left text-sm transition hover:bg-[var(--yellow)] hover:text-primary" data-transaction-option="category" data-transaction-option-id="{{ category.id|e('html_attr') }}" data-transaction-option-name="{{ category.name|e('html_attr') }}">
                                {{ category.name }}
                            </button>
                        {% endfor %}
                    </div>
                </div>

                <div class="form-group">
                    <label>entidade</label>
                    <input type="hidden" name="entity_id" data-transaction-entity-input>
                    <button type="button" class="mt-1 flex h-[29px] w-full items-center justify-between rounded border-b-[1.5px] border-[var(--lilac)] bg-transparent px-[7px] py-[3px] text-left leading-[21px] transition hover:border-[var(--purple)]" data-transaction-select-toggle="entity">
                        <span data-transaction-entity-label class="text-sm">escolha uma entidade</span>
                        <i class="fa-solid fa-chevron-down text-primary"></i>
                    </button>
                    <div class="mt-2 max-h-0 overflow-hidden rounded border border-transparent bg-[#fffff5] opacity-0 shadow-lg transition-all duration-200" data-transaction-select-menu="entity">
                        {% for entity in transaction_entities|default([]) %}
                            <button type="button" class="flex w-full items-center rounded px-3 py-2 text-left text-sm transition hover:bg-[var(--yellow)] hover:text-primary" data-transaction-option="entity" data-transaction-option-id="{{ entity.id|e('html_attr') }}" data-transaction-option-name="{{ entity.name|e('html_attr') }}">
                                {{ entity.name }}
                            </button>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div class="form-group">
                    <label>template</label>
                    <input type="hidden" name="template_id" data-transaction-template-input>
                    <button type="button" class="mt-1 flex h-[29px] w-full items-center justify-between rounded border-b-[1.5px] border-[var(--lilac)] bg-transparent px-[7px] py-[3px] text-left leading-[21px] transition hover:border-[var(--purple)]" data-transaction-select-toggle="template">
                        <span data-transaction-template-label class="text-sm">sem template</span>
                        <i class="fa-solid fa-chevron-down text-primary"></i>
                    </button>
                    <div class="mt-2 max-h-0 overflow-hidden rounded border border-transparent bg-[#fffff5] opacity-0 shadow-lg transition-all duration-200" data-transaction-select-menu="template">
                        {% for template in transaction_templates|default([]) %}
                            <button type="button" class="flex w-full items-center rounded px-3 py-2 text-left text-sm transition hover:bg-[var(--yellow)] hover:text-primary" data-transaction-option="template" data-transaction-option-id="{{ template.id|e('html_attr') }}" data-transaction-option-name="{{ template.title|e('html_attr') }}" data-template-wallet-id="{{ template.wallet.id|e('html_attr') }}" data-template-wallet-name="{{ template.wallet.name|e('html_attr') }}" data-template-category-id="{{ template.category.id|e('html_attr') }}" data-template-category-name="{{ template.category.name|e('html_attr') }}" data-template-entity-id="{{ template.entity.id|e('html_attr') }}" data-template-entity-name="{{ template.entity.name|e('html_attr') }}" data-template-amount="{{ template.amount|e('html_attr') }}" data-template-month-day="{{ template.month_day|e('html_attr') }}">
                                {{ template.title }}
                            </button>
                        {% endfor %}
                    </div>
                </div>

                <div class="form-group">
                    <label>forma de pagamento</label>
                    <input type="hidden" name="payment_method_id" data-transaction-payment-method-input>
                    <button type="button" class="mt-1 flex h-[29px] w-full items-center justify-between rounded border-b-[1.5px] border-[var(--lilac)] bg-transparent px-[7px] py-[3px] text-left leading-[21px] transition hover:border-[var(--purple)]" data-transaction-select-toggle="payment-method">
                        <span data-transaction-payment-method-label class="text-sm">escolha uma forma</span>
                        <i class="fa-solid fa-chevron-down text-primary"></i>
                    </button>
                    <div class="mt-2 max-h-0 overflow-hidden rounded border border-transparent bg-[#fffff5] opacity-0 shadow-lg transition-all duration-200" data-transaction-select-menu="payment-method">
                        {% for method in transaction_payment_methods|default([]) %}
                            <button type="button" class="flex w-full items-center rounded px-3 py-2 text-left text-sm transition hover:bg-[var(--yellow)] hover:text-primary" data-transaction-option="payment-method" data-transaction-option-id="{{ method.id|e('html_attr') }}" data-transaction-option-name="{{ method.name|e('html_attr') }}">
                                {{ method.name }}
                            </button>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
                <div class="form-group">
                    <label for="transaction-occurrence-date">data</label>
                    <input id="transaction-occurrence-date" name="occurrence_date" type="date" data-type="required" class="mt-1 h-[29px] w-full bg-transparent leading-[21px] outline-none">
                </div>
                <div class="form-group">
                    <label for="transaction-due-date">vencimento</label>
                    <input id="transaction-due-date" name="due_date" type="date" class="mt-1 h-[29px] w-full bg-transparent leading-[21px] outline-none">
                </div>
                <div class="form-group">
                    <label for="transaction-paid-at">pagamento</label>
                    <input id="transaction-paid-at" name="paid_at" type="date" class="mt-1 h-[29px] w-full bg-transparent leading-[21px] outline-none">
                </div>
            </div>

            <label class="flex cursor-pointer items-center gap-3 text-sm text-[var(--dark)]">
                <input type="hidden" name="paid" value="0">
                <input type="checkbox" name="paid" value="1" class="peer sr-only" data-transaction-paid-input>
                <span class="flex h-5 w-5 items-center justify-center rounded border-[1.5px] border-[var(--lilac)] text-[0px] text-light transition peer-checked:bg-[var(--lilac)] peer-checked:text-xs">
                    <i class="fa-solid fa-check"></i>
                </span>
                pago
            </label>
        </div>

        <div class="flex justify-end gap-3 px-6 py-4">
            <button type="button" class="btn-secondary" data-close-transaction-modal>
                cancelar
            </button>
            <button type="submit" class="btn-primary">
                <i class="fa-solid fa-check"></i>
                salvar
            </button>
        </div>
    </form>
</dialog>
